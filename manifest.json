{
  "name": "Jira Tools",
  "description": "Jira Tools (copy issue key to clipboard)",
  "version": "1.4.1",
  "manifest_version": 3,
  "content_scripts": [
    {
      "matches": [
        "https://*.atlassian.net/browse/*",
        "https://*.atlassian.net/jira/*",
        "https://*.atlassian.net/wiki/*"
      ],
      "js": [
        "/js/common.js",
        "/js/copy_issue_key.js"
      ]
    }
  ],
  "permissions": ["clipboardWrite"],
  "icons": {
    "128": "icon128.png"
  }
}
